{
  "hooks": [
    {
      "event": "PostToolUse",
      "matcher": {
        "tool_name": "Edit"
      },
      "hooks": [
        {
          "type": "command",
          "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/format-check.sh",
          "timeout": 30
        }
      ]
    },
    {
      "event": "PostToolUse",
      "matcher": {
        "tool_name": "Write"
      },
      "hooks": [
        {
          "type": "command",
          "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/format-check.sh",
          "timeout": 30
        }
      ]
    },
    {
      "event": "PreToolUse",
      "matcher": {
        "tool_name": "Bash"
      },
      "hooks": [
        {
          "type": "command",
          "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/git-guardrail.sh",
          "timeout": 10
        }
      ]
    }
  ]
}
